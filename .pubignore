# Dart/Flutter build artifacts (a root .pubignore overrides the root
# .gitignore, so these must be repeated here).
build/
.dart_tool/
.packages
pubspec.lock
*.iml
.idea/
.flutter-plugins
.flutter-plugins-dependencies

# Keep the published archive lean: ship the example source, not its
# generated platform scaffolding.
example/android/
example/ios/
example/linux/
example/macos/
example/windows/
example/web/
example/build/
example/.dart_tool/
example/.flutter-plugins
example/.flutter-plugins-dependencies
example/pubspec.lock
example/screen_launcher_example.iml

# README preview image is hosted via raw GitHub URL; no need to ship it.
doc/
